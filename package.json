{
  "name": "llama-cpp-server-explorer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,magenta \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "build": "tsc -p server/tsconfig.json && vite build --config client/vite.config.ts",
    "start": "node server/dist/index.js",
    "typecheck": "tsc -p server/tsconfig.json --noEmit && tsc -p client/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "3.1068.0",
    "@hono/node-server": "2.0.4",
    "@octokit/request": "10.0.10",
    "better-sqlite3": "12.10.0",
    "hono": "4.12.25",
    "marked": "18.0.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.10.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "10.0.3",
    "idb": "8.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  },
  "packageManager": "pnpm@11.5.2"
}
